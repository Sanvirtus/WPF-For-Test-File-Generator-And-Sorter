<Window x:Class="Wpf_For_Test_File_Generator_And_Sorter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:constants="clr-namespace:Wpf_For_Test_File_Generator_And_Sorter.Constants"
        xmlns:viewModels="clr-namespace:Wpf_For_Test_File_Generator_And_Sorter.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=False}"
        Title="WPF Example" Height="600" Width="800" MinHeight="400" MinWidth="600">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{DynamicResource MenuFile}">
                <Separator />
                <MenuItem Header="{DynamicResource MenuExit}"
                          Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuGenAndSort}">
                <MenuItem Header="{DynamicResource MenuGenAndSortTab}"
                          Click="OpenGenAndSortTab_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuAbout}">
                <MenuItem Header="{DynamicResource MenuLanguage}"
                          Name="LanguageMenu" />
            </MenuItem>
        </Menu>

        <TabControl Name="MainTabControl"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding HeaderKey, Converter={StaticResource ResConverter}}"
                                   VerticalAlignment="Center" FontSize="14" />
                        <TextBlock Text="{Binding IndexSuffix}"
                                   VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14" />
                        <Button Click="CloseTab_Click"
                                CommandParameter="{Binding}"
                                VerticalAlignment="Center"
                                Margin="5,0,0,0"
                                Cursor="Hand">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <TextBlock Text="{x:Static constants:AppConstants.CrossConstant}"
                                       Foreground="Red"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Margin="0,-2,0,0" />
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentPresenter Content="{Binding Content}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>