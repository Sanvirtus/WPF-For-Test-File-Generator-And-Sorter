<Application x:Class="Wpf_For_Test_File_Generator_And_Sorter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:resources="clr-namespace:Wpf_For_Test_File_Generator_And_Sorter.Resources">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Lang.en-US.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <resources:DynamicResourceConverter x:Key="ResConverter" />
            <resources:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>